# Copy to .env and fill in values
# Only needed when running in API mode (--mode=api)

# Anthropic API key (required for mode=api)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional — only if using OpenAI cloud, not LMStudio)
# OPENAI_API_KEY=sk-...

# Override default Ollama URL (optional)
# OLLAMA_BASE_URL=http://localhost:11434

# Override default LMStudio URL (optional)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
